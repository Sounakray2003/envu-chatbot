# Exclude everything by default; the Dockerfile copies only the runtime API
# and service package needed for ingestion.
**

# Runtime source
!requirements.txt
!retrieval_new.py
!admin_api.py
!services/
!services/**

# Docker metadata useful during build/debug
!Dockerfile
!.dockerignore

# Never include local data, secrets, generated files, or git metadata.
.env
.env.*
.git/
.github/
__pycache__/
*.py[cod]
logs/
uploads/
uploaded_files/
file_registry/
output_files/
testfiles/
*.pdf
*.zip
*.tar
*.pem
*.key
